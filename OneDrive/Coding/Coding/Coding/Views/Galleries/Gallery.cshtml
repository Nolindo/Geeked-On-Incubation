@model IEnumerable<Coding.Models.Gallery>

@{
    ViewBag.Title = "Image Gallery";
}
<div class="text-center mb-4">

    <a href="@Url.Action("Gallery")" class="btn btn-dark m-1">
        All
    </a>

    @foreach (var category in ViewBag.Categories)
    {
        <a href="@Url.Action("Gallery", new { categoryId = category.CategoryId })"
           class="btn btn-outline-primary m-1">
            @category.CategoryName
        </a>
    }

</div>

<div class="container mt-5">

    <div class="text-center mb-5">

        <h1 class="display-4">Image Gallery</h1>

        <p class="lead text-muted">
            Explore our collection of beautiful images.
        </p>

    </div>

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">

                <div class="card gallery-card shadow">

                    <a href="@Url.Content("~/Uploads/" + item.FileName)"
                       data-lightbox="gallery"
                       data-title="@item.ImageTitle - @item.ImageDescription">

                        <img src="@Url.Content("~/Uploads/" + item.FileName)"
                             class="card-img-top gallery-image"
                             alt="@item.ImageTitle" />
                    </a>
                    <div class="card-body">

                        <h5 class="card-title">
                            @item.ImageTitle
                        </h5>

                        <p class="card-text text-muted">
                            @item.ImageDescription
                        </p>
                        <small class="text-primary">
                            @item.Categories.CategoryName
                        </small>

                    </div>

                </div>

            </div>
        }

    </div>

</div>